{
  "entities": {
    "apkFile": {
      "title": "APK File",
      "description": "Metadata for an uploaded APK file.",
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique ID for the file."
        },
        "name": {
          "type": "string",
          "description": "Original filename."
        },
        "size": {
          "type": "number",
          "description": "File size in bytes."
        },
        "totalChunks": {
          "type": "number",
          "description": "Total number of chunks stored in Firestore."
        },
        "downloadUrl": {
          "type": "string",
          "description": "Public download URL for the file."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the file was uploaded."
        }
      },
      "required": ["id", "name", "size", "totalChunks", "downloadUrl", "createdAt"]
    },
    "apkFileChunk": {
      "title": "APK File Chunk",
      "description": "A single chunk of an APK file.",
      "type": "object",
      "properties": {
        "index": {
          "type": "number",
          "description": "Index of the chunk."
        },
        "data": {
          "type": "string",
          "description": "Base64 encoded chunk data."
        }
      },
      "required": ["index", "data"]
    }
  },
  "firestore": {
    "/apkFiles/{fileId}": {
      "schema": "apkFile",
      "description": "Collection of uploaded APK file metadata."
    },
    "/apkFiles/{fileId}/chunks/{chunkId}": {
      "schema": "apkFileChunk",
      "description": "Subcollection of APK file chunks."
    }
  }
}
